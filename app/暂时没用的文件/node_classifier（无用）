import time
from pydantic import BaseModel, Field
from app.llm_factory import LLMFactory
from state import AgentState

class RouteDecision(BaseModel):
    route: str = Field(description="必须是 'baseline' 或 'agentic'")
    reason: str = Field(description="做出该路由判定的简短理由")

def classifier_node(state: AgentState):
    """复杂度分类节点"""
    query = state.get("original_request", "")
    print(f"\n{'=' * 60}")
    print(f"🚦 [分类节点] 正在分析案情复杂度...")
    start_time = time.time()

    # 推荐使用较快/较便宜的模型做分类
    llm = LLMFactory.get_gpt()
    structured_llm = llm.with_structured_output(RouteDecision, method="json_mode")

    prompt = f"""你是一个智能法律问答系统的【中央路由裁判】。
你的唯一任务是：评估用户的法律问题复杂程度，并将其分发给最合适的底层系统。

【路由分发标准】
1. 走 'baseline' (静态基础RAG)：
   - 问题极其简单、明确，缺乏具体案情。
   - 直接询问某部法律、某个法条的具体规定、或通用流程。
   - 示例：“《民法典》关于抵押权的规定是什么？”、“国家赔偿费用由谁管理？”

2. 走 'agentic' (多智能体RAG)：
   - 问题复杂，是一段具体的、带有故事情节的现实纠纷（Scenario）。
   - 包含多跳逻辑，需要搜集多个法条综合判断（Multi-hop）。
   - 提到了特定的公司、公众人物或近期的热点新闻事件。

【输出格式】
请输出JSON格式，包含 route (值为 baseline 或 agentic) 和 reason。

用户问题：{query}"""

    try:
        decision = structured_llm.invoke(prompt)
        elapsed = round(time.time() - start_time, 2)
        route_choice = decision.route if decision.route in ["baseline", "agentic"] else "agentic"
        print(f"  -> 🔀 [判定结果]: 走 【{route_choice.upper()}】 系统 (耗时: {elapsed}s)")
        print(f"  -> 📝 [判定理由]: {decision.reason}")
        return {"route": route_choice, "executed_system": route_choice}
    except Exception as e:
        print(f"  -> ⚠️ 分类失败，默认切换至 Agentic RAG: {e}")
        return {"route": "agentic", "executed_system": "agentic"}